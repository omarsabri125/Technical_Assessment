LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

LLM_PROVIDER=GROQ

GROQ_API_KEY=gsk_your_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

TAVILY_API_KEY=tvly-your-key
TAVILY_MAX_RESULTS=3
TAVILY_SEARCH_DEPTH=basic

STT_PROVIDER=DEEPGRAM
DEEPGRAM_STT_MODEL=deepgram/nova-3
DEEPGRAM_STT_LANGUAGE=ar-EG

ASSEMBLYAI_STT_MODEL=assemblyai/universal-3-5-pro
ASSEMBLYAI_STT_LANGUAGE=ar

TTS_PROVIDER=CARTESIA 
CARTESIA_TTS_MODEL=cartesia/sonic-3
CARTESIA_TTS_VOICE=9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
LIVEKIT_TTS_LANGUAGE=ar

ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_TTS_VOICE=your_elevenlabs_voice_id

TEMPERATURE=0
AEC_WARMUP_DURATION=2.0
FALSE_INTERRUPTION_TIMEOUT=1.0
PREEMPTIVE_GENERATION_MAX_RETRIES=3